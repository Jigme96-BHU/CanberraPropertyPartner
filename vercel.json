{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "X-Content-Type-Options",     "value": "nosniff" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security",  "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    { "source": "/recent-rental-properties",  "destination": "/rental", "permanent": true },
    { "source": "/awards-and-testimonials",   "destination": "/awards", "permanent": true },
    { "source": "/testimonials-1",            "destination": "/awards", "permanent": true }
  ],
  "functions": {
    "pages/api/cron/sync-listings.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-listings",
      "schedule": "*/5 * * * *"
    }
  ]
}
