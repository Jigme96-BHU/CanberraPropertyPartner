# ─────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git — it is gitignored.
#
# All variables must also be added to Vercel:
#   Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Hetzner Storage Box — where Reapit drops REAXML listing files via SFTP
HETZNER_HOST=u000000.your-storagebox.de
HETZNER_USERNAME=u000000
HETZNER_PASSWORD=your-password-here

# Resend API key — used by pages/api/contact.js to send contact form emails
# Sign up at https://resend.com and create an API key
# For production: verify canberrapropertypartners.com.au in Resend and
# update the `from:` fields in pages/api/contact.js to use your domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
